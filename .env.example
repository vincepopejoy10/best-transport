# ─── Lead Pipeline CRM — Environment Variables ───────────────────────────────
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Optional: hard-code your GHL API key here so you don't have to type it in the UI.
# If set, the proxy uses this key for every request regardless of what the UI sends.
# If left blank, the key entered in the CRM UI is forwarded via the X-GHL-Api-Key header.
GHL_API_KEY=

# Port for the local Express server (default: 3001)
PORT=3001
